# Project Config
PROJECT_NAME=app-inertia-react

# PHP Version (e.g. 8.3, 8.2, 8.1)
PHP_VERSION=8.3

# Laravel Version (leave empty for latest, e.g. "11.*", "10.*")
LARAVEL_VERSION=

# Nginx Webserver Config
WEBSERVER_PORT=8002

# Vite Dev Server Config
VITE_PORT=5174

# MySQL Database Config
DB_PORT=3307
DB_DATABASE=laravel_db
DB_USERNAME=laravel_user
DB_PASSWORD=laravel_password

# Redis Config
REDIS_PORT=6381

# Mailpit Config
MAILPIT_PORT=8027
MAILPIT_SMTP_PORT=1027
